	 #page .sprites {
		background-image: url();
	}

	.sprite-back2old{ background-position: 0 4px; background-repeat:no-repeat; margin-left:18px;} 
	.sprite-footer{ background-position: 0 -40px; background-repeat:repeat-x;} 
	.sprite-header{ background-position: 0 -172px; background-repeat:repeat-x;} 
	.sprite-mobile{ background-position: 0 -227px; background-repeat:no-repeat; border-right: 1px solid #E2E2E2;} 
	.sprite-spe{ background-position: 0 -271px; background-repeat:no-repeat;} 

 </style>
        <script src="404/jquery-1.7.2.min.js"></script>
        <script type="text/javascript">
            $(function() {
                var h = $(window).height();
                $('body').height(h);
                $('.mianBox').height(h-250);
                centerWindow(".tipInfo");
            });

            //2.将盒子方法放入这个方，方便法统一调用
            function centerWindow(a) {
                center(a);
                //自适应窗口
                $(window).bind('scroll resize',
                        function() {
                            center(a);
                        });
            }

            //1.居中方法，传入需要剧中的标签
            function center(a) {
                var wWidth = $(window).width();
                var wHeight = $(window).height();
                var boxWidth = $(a).width();
                var boxHeight = $(a).height()+350;
                var scrollTop = $(window).scrollTop();
                var scrollLeft = $(window).scrollLeft();
                var top = scrollTop + (wHeight - boxHeight) / 2;
                var left = scrollLeft + (wWidth - boxWidth) / 2;
                $(a).css({
                    "top": top,
                    "left": left
                });
            }
        </script>

    </head>

 

 <body>

	<div id="page">
		<div id="header" class="sprites sprite-header">
			<div id="tapBar"><a href="https://www.kvjv.com/" target="_blank" class="sprites sprite-back2old">浩爽制冷</a>
